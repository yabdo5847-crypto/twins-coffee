# ══════════════════════════════════════════
#  The Twins Coffee® — Environment Variables
#  Copy this file to .env and fill in values
# ══════════════════════════════════════════

# ─── Supabase ───────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Server ─────────────────────────────────
PORT=3000

# ─── Admin ──────────────────────────────────
# The email you'll use to login to the admin panel
# Create this user in Supabase → Authentication → Users → Add User
ADMIN_EMAIL=admin@thetwinscoffee.com
