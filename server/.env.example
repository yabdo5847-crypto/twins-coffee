# ══════════════════════════════════════════
#  The Twins Coffee® — Environment Variables
#  Copy this file to .env and fill in values
# ══════════════════════════════════════════

# ─── Server ─────────────────────────────────
PORT=3000

# ─── Security ───────────────────────────────
# Change this to a strong random secret in production
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Paymob ─────────────────────────────────
# Get these from https://accept.paymob.com/portal2/en/home
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID_CARD=your-card-integration-id
PAYMOB_INTEGRATION_ID_FAWRY=your-fawry-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC=your-hmac-secret
